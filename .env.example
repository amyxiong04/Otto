# Environment Variables

# OpenAI API key for chat, analysis, and speech-to-text
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Resend sends the finished results by email
# Verify the sender domain in Resend before using it in production
RESEND_API_KEY=your_resend_api_key_here
RESULTS_FROM_EMAIL="Otto <results@yourdomain.com>"

# Optional: raises the GitHub API rate limit for public profile lookups
GITHUB_TOKEN=your_github_token_here
